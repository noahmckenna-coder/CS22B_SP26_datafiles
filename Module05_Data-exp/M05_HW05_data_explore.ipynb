# Data Exploration Solutions

import pandas as pd

# Load the data
# Replace 'your_data_file.csv' with the actual data file you are using

df = pd.read_csv('your_data_file.csv')

# 1. Show the first few rows of the dataframe.
df.head()

# 2. Summary statistics
summary_stats = df.describe()
print(summary_stats)

# 3. Check for missing values
missing_values = df.isnull().sum()
print(missing_values)

# 4. Group by a specific column and compute mean
mean_values = df.groupby('your_grouping_column').mean()
print(mean_values)

# 5. Create a plot
import matplotlib.pyplot as plt

plt.figure(figsize=(10, 6))
df['your_column_name'].hist()
plt.title('Histogram of Your Column')
plt.xlabel('Value')
plt.ylabel('Frequency')
plt.show()